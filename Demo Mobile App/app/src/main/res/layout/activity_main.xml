<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BROADCAST RECEIVER DEMO"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- ============================== -->
        <!--  SECTION 1: SYSTEM BROADCASTS  -->
        <!-- ============================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. SYSTEM BROADCASTS (Dynamic Receiver)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_marginBottom="8dp" />

        <!-- Network Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trang thai mang (CONNECTIVITY_ACTION)"
                android:textSize="12sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvNetworkStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dang kiem tra..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Battery Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trang thai pin (BATTERY_CHANGED)"
                android:textSize="12sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvBatteryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dang kiem tra..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Airplane Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Che do may bay (AIRPLANE_MODE_CHANGED)"
                android:textSize="12sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvAirplaneStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dang kiem tra..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ============================== -->
        <!--  SECTION 2: CUSTOM BROADCAST   -->
        <!-- ============================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. CUSTOM BROADCAST"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/edtMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhap thong diep..."
                android:inputType="text" />

            <Button
                android:id="@+id/btnSendBroadcast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gui Custom Broadcast"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnSendGlobalBroadcast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gui Global Broadcast"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnOpenSecondActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mo Second Activity"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Custom Message (CUSTOM_ACTION)"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvCustomMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dang kiem tra..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. EVENT LOG"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:minHeight="150dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for events..."
                android:textSize="11sp"
                android:textColor="#333333"
                android:fontFamily="monospace" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
